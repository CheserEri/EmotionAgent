{
  "manifest_version": 3,
  "name": "Emotion Agent",
  "version": "1.0.0",
  "description": "在任意网页显示 3D AI 角色，支持对话和表情驱动",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["http://127.0.0.1:8765/*"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["lib/*", "models/*", "styles.css", "model-viewer.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/icon16.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    }
  },
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  }
}
